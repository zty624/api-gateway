# FastAPI config path inside the container.
GATEWAY_CONFIG=/app/config.yaml

# The only public container port. nginx listens here and routes /api/ and /tunnel/.
PUBLIC_PORT=8080

# Optional: newline-separated public keys, or mount /app/authorized_keys.
GATEWAY_AUTHORIZED_KEYS=

# Optional: explicit rtunnel startup path. If missing, entrypoint downloads it.
RTUNNEL_BINARY=./bin/rtunnel
